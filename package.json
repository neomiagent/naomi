{
  "name": "naomi-scanner",
  "version": "0.2.2",
  "homepage": "https://github.com/neomiagent/naomi",
  "description": "Naomi — autonomous forensic analyzer for Solana token launches. Watches pump.fun + raydium-launchpad, snapshots the first 60 seconds (buyers, jito bundles, dev wallet), scores with Claude. No trading, just verdicts.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "naomi": "dist/index.js",
    "naomi-scanner": "dist/index.js"
  },
  "files": [
    "dist",
    "config.example.yaml",
    ".env.example",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neomiagent/naomi.git"
  },
  "bugs": {
    "url": "https://github.com/neomiagent/naomi/issues"
  },
  "author": "neomiagent",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "scan": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "pumpfun",
    "raydium",
    "launchpad",
    "token-launch",
    "first-60-seconds",
    "jito",
    "sniper-detection",
    "rug-detection",
    "ai",
    "claude",
    "agent",
    "naomi"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.8",
    "@metaplex-foundation/mpl-token-metadata": "^3.2.0",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
