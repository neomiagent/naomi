# =====================================================
# Naomi — Solana Token Launch Forensic Analyzer
# Copy this file to .env and fill in your own values.
# Never commit .env to git.
# =====================================================

# --- Solana RPC ---
# Use a paid provider (Helius, QuickNode, Triton, Shyft). Public mainnet-beta
# rate-limits aggressively and will not keep up with launch volume.
SOL_RPC_URL=
# Optional WebSocket endpoint, required for the geyser source.
SOL_WS_URL=

# --- Geyser / shredstream (optional, recommended for production) ---
# yellowstone-grpc geyser endpoint. low-latency account + tx feed.
SOL_GEYSER_GRPC_URL=

# --- Helius ---
# Optional. Used for enhanced tx decoding, holder lookups, and metadata.
# Without it, contract and holder enrichment degrade gracefully.
HELIUS_API_KEY=

# --- Jito block engine (public, no key) ---
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# --- Anthropic / Claude (AI scoring) ---
# Optional. If unset, Naomi runs heuristic-only filtering.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Logging ---
LOG_LEVEL=info
