# =====================================================
# Naomi — Solana AI Sniper Agent
# Copy this file to .env and fill in your own values.
# Never commit .env to git.
# =====================================================

# --- Mode ---
# paper = log decisions only, no on-chain action
# live  = real buys via Jito bundles
MODE=paper

# --- Solana RPC ---
# Use a paid provider (Helius, QuickNode, Triton). Free RPC will not handle the load.
SOLANA_RPC_URL=
SOLANA_WS_URL=

# --- Geyser / LaserStream (real-time stream of new pools) ---
# Helius LaserStream endpoint or Yellowstone Geyser gRPC
GEYSER_GRPC_URL=
GEYSER_TOKEN=

# --- Wallet ---
# Base58-encoded private key of the hot wallet used for sniping.
# Use a dedicated wallet, fund it with only what you can lose.
WALLET_PRIVATE_KEY=

# --- Jito ---
# Jito block engine URL for your region:
#   https://mainnet.block-engine.jito.wtf
#   https://amsterdam.mainnet.block-engine.jito.wtf
#   https://frankfurt.mainnet.block-engine.jito.wtf
#   https://ny.mainnet.block-engine.jito.wtf
#   https://tokyo.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=
JITO_TIP_LAMPORTS=100000

# --- Anthropic / Claude (AI filter) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Logging ---
LOG_LEVEL=info
